#!/usr/bin/env zsh

FONT_FACE="JetBrainsMono Nerd Font"

PLUGIN_DIR="$HOME/.config/sketchybar/plugins-laptop"
PLUGIN_SHARED_DIR="$HOME/.config/sketchybar/plugins"

SPOTIFY_EVENT="com.spotify.client.PlaybackStateChanged"

# Add custom event for aerospace workspace changes
sketchybar --add event aerospace_workspace_change

sketchybar --bar \
    height=24 \
    color=0x00000000 \
    margin=0 \
    sticky=on \
    padding_left=4 \
    padding_right=4 \
    notch_width=196 \
    notch_display_height=36

# Alternatiive background colors
# label.color=0xffffffff
# background.color=0x9924273a
sketchybar --default \
    background.color=0xAA494d64 \
    background.corner_radius=5 \
    background.padding_right=5 \
    background.height=24 \
    icon.font="$FONT_FACE:Medium:15.0" \
    icon.padding_left=5 \
    icon.padding_right=5 \
    label.font="$FONT_FACE:Medium:12.0" \
    label.color=0xffcad3f5 \
    label.y_offset=0 \
    label.padding_left=0 \
    label.padding_right=5 \
    popup.blur_radius=30 \
    popup.background.color=0xAA494d64 \
    popup.background.corner_radius=8 \
    popup.background.shadow.drawing=on
sketchybar --add event spotify_change $SPOTIFY_EVENT

# Get number of monitors from aerospace
MONITOR_COUNT=$(aerospace list-monitors 2>/dev/null | wc -l | tr -d ' ')
if [[ -z "$MONITOR_COUNT" || "$MONITOR_COUNT" -eq 0 ]]; then
    MONITOR_COUNT=1
fi

# Create workspace and front_app items for each display
for ((i=1; i<=MONITOR_COUNT; i++)); do
    # Current workspace item for display $i
    sketchybar --add item "current_space.$i" left \
        --set "current_space.$i" \
        associated_display=$i \
        background.color=0xfff5a97f \
        icon.font="$FONT_FACE:Medium:15.0" \
        icon.color=0xff24273a \
        icon.padding_left=5 \
        icon.padding_right=2 \
        label.drawing=off \
        script="$PLUGIN_SHARED_DIR/current_space_per_display.sh" \
        click_script="$PLUGIN_SHARED_DIR/toggle_workspaces_popup.sh" \
        popup.drawing=off \
        popup.horizontal=off \
        --add item "current_space.$i.separator" left \
        --set "current_space.$i.separator" \
        associated_display=$i \
        background.color=0x00000000 \
        background.padding_left=-8 \
    icon= \
        icon.color=0xfff5a97f \
        icon.font="$FONT_FACE:Bold:20.0" \
        icon.padding_left=0 \
        icon.padding_right=0 \
        icon.y_offset=1 \
        label.drawing=no \
        --add item "current_space.$i.name" left \
        --set "current_space.$i.name" \
        associated_display=$i \
        background.color=0x00000000 \
        background.padding_right=5 \
        icon.drawing=off \
        label.font="$FONT_FACE:Bold:12.0" \
        label.padding_left=2 \
        label.drawing=yes

    # Front app item for display $i
    sketchybar --add item "front_app.$i" left \
        --set "front_app.$i" \
        associated_display=$i \
        background.color=0xffa6da95 \
        background.padding_left=0 \
        background.padding_right=0 \
        icon.y_offset=1 \
        icon.color=0xff24273a \
        label.drawing=no \
        script="$PLUGIN_SHARED_DIR/front_app_per_display.sh" \
        --add item "front_app.$i.separator" left \
        --set "front_app.$i.separator" \
        associated_display=$i \
        background.color=0x00000000 \
        background.padding_left=-3 \
    icon= \
        icon.color=0xffa6da95 \
        icon.font="$FONT_FACE:Bold:20.0" \
        icon.padding_left=0 \
        icon.padding_right=0 \
        icon.y_offset=1 \
        label.drawing=no \
        --add item "front_app.$i.name" left \
        --set "front_app.$i.name" \
        associated_display=$i \
        background.color=0x00000000 \
        background.padding_right=0 \
        icon.drawing=off \
        label.font="$FONT_FACE:Bold:12.0" \
        label.drawing=yes

    # Subscribe items to events
    sketchybar --add bracket "front_app_bracket_$i" \
        "front_app.$i" \
        "front_app.$i.separator" \
        "front_app.$i.name" \
        --subscribe "front_app.$i" front_app_switched aerospace_workspace_change

    sketchybar --add bracket "current_space_bracket_$i" \
        "current_space.$i" \
        "current_space.$i.separator" \
        "current_space.$i.name" \
        --subscribe "current_space.$i" front_app_switched aerospace_workspace_change
done

sketchybar --add item weather center \
    --set weather \
    associated_display=1 \
    background.padding_left=5 \
    background.padding_right=5 \
    icon= \
    icon.color=0xfff5bde6 \
    icon.font="$FONT_FACE:Bold:15.0" \
    update_freq=600 \
    script="$PLUGIN_SHARED_DIR/weather.sh" \
    --subscribe weather system_woke

sketchybar --add item weather.moon center \
    --set weather.moon \
    associated_display=1 \
    background.color=0xAA494d64 \
    background.padding_left=5 \
    background.padding_right=5 \
    icon.drawing=off \
    label.drawing=on \
    label.color=0xffcad3f5 \
    label.font="$FONT_FACE:Medium:11.0" \
    label.padding_left=8 \
    label.padding_right=8 \
    click_script="$PLUGIN_SHARED_DIR/toggle_weather_stats.sh" \
    --subscribe weather.moon mouse.clicked

sketchybar --add item spotify center \
    --set spotify \
    associated_display=1 \
    background.padding_left=5 \
    icon=$'\uf1bc' \
    icon.y_offset=1 \
    icon.font="$FONT_FACE:Bold:20.0" \
    label.drawing=off \
    label.padding_left=3 \
    script="$PLUGIN_DIR/spotify.sh" \
    --subscribe spotify spotify_change mouse.clicked

# Built-in display (notch-aware positions)
sketchybar --add item weather.moon.notch q \
    --set weather.moon.notch \
    associated_display=2 \
    background.color=0xAA494d64 \
    background.padding_left=10 \
    background.padding_right=0 \
    icon.drawing=off \
    label.drawing=on \
    label.color=0xffcad3f5 \
    label.font="$FONT_FACE:Medium:11.0" \
    label.padding_left=8 \
    label.padding_right=8 \
    click_script="$PLUGIN_SHARED_DIR/toggle_weather_stats.sh" \
    --subscribe weather.moon.notch mouse.clicked

sketchybar --add item weather.notch q \
    --set weather.notch \
    associated_display=2 \
    background.padding_left=5 \
    background.padding_right=0 \
    icon.color=0xfff5bde6 \
    icon.font="$FONT_FACE:Bold:15.0" \
    update_freq=1800 \
    script="$PLUGIN_SHARED_DIR/weather.sh" \
    --subscribe weather.notch system_woke

sketchybar --add item spotify.notch e \
    --set spotify.notch \
    icon=$'\uf1bc' \
    associated_display=2 \
    icon.y_offset=1 \
    icon.font="$FONT_FACE:Bold:20.0" \
    label.drawing=off \
    label.padding_left=3 \
    script="$PLUGIN_DIR/spotify.sh" \
    --subscribe spotify.notch spotify_change mouse.clicked

sketchybar --add item clock right \
    --set clock \
    icon=󰃰 \
    icon.color=0xffed8796 \
    update_freq=5 \
    background.padding_right=0 \
    script="$PLUGIN_SHARED_DIR/clock.sh"

sketchybar --add item wifi right \
    --set wifi \
    icon.color=0xff91D7E3 \
    label.drawing=true \
    update_freq=20 \
    script="$PLUGIN_DIR/wifi.sh"

sketchybar --add item battery right \
    --set battery \
    update_freq=20 \
    script="$PLUGIN_DIR/battery.sh"

sketchybar --add item volume right \
    --set volume \
    icon.color=0xff8aadf4 \
    label.drawing=true \
    script="$PLUGIN_SHARED_DIR/volume.sh" \
    --subscribe volume volume_change

##### Finalizing Setup #####
sketchybar --update
sketchybar --trigger aerospace_workspace_change
