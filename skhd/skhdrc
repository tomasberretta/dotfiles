#
# Aerospace - rcmd bindings (aerospace doesn't support left/right cmd distinction)
#

rcmd - f : aerospace fullscreen
rcmd - b : aerospace balance-sizes
rcmd - space : aerospace layout floating tiling

# Workspaces
rcmd - 1 : aerospace workspace Browser
rcmd - 2 : aerospace workspace Terminal
rcmd - 3 : aerospace workspace Communication
rcmd - 4 : aerospace workspace Dev
rcmd - 5 : aerospace workspace Issues
rcmd - q : aerospace workspace Misc
rcmd - w : aerospace workspace Notes
rcmd - e : aerospace workspace Meetings
rcmd - r : aerospace workspace Temp
rcmd - t : aerospace move-node-to-workspace Temp

