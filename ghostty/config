font-size = 13
font-style = medium
bold-is-bright = true
font-family = "JetBrainsMono Nerd Font Mono"

# Onyx theme - Generated from centralized palette
background = 151311
foreground = eed3ba

# Cursor colors
cursor-color = 9fbde0
cursor-text = 151311

# Selection colors  
selection-background = 4b262f
selection-foreground = eed3ba

# Normal colors (ANSI 0-7)
palette = 0=0a0908
palette = 1=e87462
palette = 2=b8c47c
palette = 3=f0c97d
palette = 4=9fbde0
palette = 5=c28a9a
palette = 6=a8c8c2
palette = 7=eed3ba

# Bright colors (ANSI 8-15)
palette = 8=a08d7d
palette = 9=e87462
palette = 10=b8c47c
palette = 11=f0c97d
palette = 12=9fbde0
palette = 13=c28a9a
palette = 14=a8c8c2
palette = 15=4b262f

# Cursor settings
cursor-style = block
cursor-style-blink = false

# Clipboard
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true

# Mouse
mouse-scroll-multiplier = 0.2
mouse-hide-while-typing = true

# Scrolling improvements
scrollback-limit = 100000
adjust-cell-width = 0
adjust-cell-height = 0

# Performance and smoothness optimizations
unfocused-split-opacity = 0.7
resize-overlay-position = center

# Experimental smoothness settings
working-directory = inherit
shell-integration = fish
osc-color-report-format = 8-bit

# Window
initial-window = true
resize-overlay = never
background-opacity = 1.00
window-save-state = always
window-step-resize = false
background-blur-radius = 35
window-padding-balance = true
confirm-close-surface = false

# Behavior
auto-update = check
auto-update-channel = stable
quit-after-last-window-closed = true
shell-integration-features = true

# macOS
macos-option-as-alt = true
macos-titlebar-style = hidden

# macOS performance optimizations for smoothness
macos-non-native-fullscreen = false
