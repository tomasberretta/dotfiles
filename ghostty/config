font-size = 16
font-style = medium
bold-is-bright = true
font-family = "JetBrainsMono Nerd Font Mono"

# IntelliJ New UI Dark theme
background = 1e1f22
foreground = bcbec4

# Cursor colors
cursor-color = 56a8f5
cursor-text = 1e1f22

# Selection colors
selection-background = 214283
selection-foreground = bcbec4

# Normal colors (ANSI 0-7)
palette = 0=1e1f22
palette = 1=f75464
palette = 2=6aab73
palette = 3=f2c55c
palette = 4=56a8f5
palette = 5=c77dbb
palette = 6=2aacb8
palette = 7=bcbec4

# Bright colors (ANSI 8-15)
palette = 8=6f737a
palette = 9=f75464
palette = 10=6aab73
palette = 11=f2c55c
palette = 12=56a8f5
palette = 13=c77dbb
palette = 14=2aacb8
palette = 15=dfe1e5

# Cursor settings
cursor-style = block
cursor-style-blink = false

# Clipboard
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true

# Mouse
mouse-scroll-multiplier = 0.2
mouse-hide-while-typing = true

# Scrolling improvements
scrollback-limit = 100000
adjust-cell-width = 0
adjust-cell-height = 0

# Performance and smoothness optimizations
unfocused-split-opacity = 0.7
resize-overlay-position = center

# Experimental smoothness settings
working-directory = inherit
shell-integration = zsh
osc-color-report-format = 8-bit

# Window
initial-window = true
resize-overlay = never
background-opacity = 1.00
window-save-state = always
window-step-resize = false
background-blur-radius = 35
window-padding-balance = true
confirm-close-surface = false

# Behavior
auto-update = check
auto-update-channel = stable
quit-after-last-window-closed = true
shell-integration-features = true

# macOS
macos-option-as-alt = true
macos-titlebar-style = hidden

keybind = cmd+t=new_tab

# macOS performance optimizations for smoothness
macos-non-native-fullscreen = false
